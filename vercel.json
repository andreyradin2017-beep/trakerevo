{
  "rewrites": [
    {
      "source": "/api/rawg/(.*)",
      "destination": "https://api.rawg.io/api/$1"
    },
    {
      "source": "/api/kinopoisk/(.*)",
      "destination": "https://kinopoiskapiunofficial.tech/api/$1"
    },
    {
      "source": "/api/tmdb/(.*)",
      "destination": "https://api.themoviedb.org/3/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/tmdb-image/(.*)",
      "destination": "https://image.tmdb.org/t/p/$1"
    },
    {
      "source": "/((?!api/|tmdb-image/).*)",
      "destination": "/index.html"
    }
  ]
}
